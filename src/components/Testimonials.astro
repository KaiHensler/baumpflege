---
const testimonials = [
  {
    name: 'Markus W.',
    location: 'Heidelberg',
    stars: 5,
    text: 'Herr Kern hat unsere 18m-Fichte in wenigen Stunden sicher abgetragen — trotz engem Grundstück direkt am Nachbarzaun. Kein Schaden, alles aufgeräumt, fairer Preis. Absolute Empfehlung.'
  },
  {
    name: 'Sabine L.',
    location: 'Weinheim',
    stars: 5,
    text: 'Nach dem Sturm im Oktober hatten wir einen abgebrochenen Ast auf dem Dach. Herr Kern war noch am selben Tag da. Schnell, kompetent, freundlich. Gerne wieder — hoffentlich ohne Sturm.'
  },
  {
    name: 'Familie Richter',
    location: 'Ladenburg',
    stars: 5,
    text: 'Wir haben drei Angebote eingeholt. Kern Baumpflege war nicht der günstigste — aber der einzige der uns erklärt hat, warum ein fachgerechter Schnitt langfristig günstiger ist als billiges Abholzen. Das Ergebnis ist großartig.'
  }
];
---

<section class="section" id="bewertungen" aria-labelledby="bewertungen-headline">
  <div class="container">
    <div class="section__header" data-reveal>
      <h2 class="section__headline" id="bewertungen-headline">Was unsere Kunden sagen</h2>
      <p class="section__sub">
        <span class="text-accent" style="font-weight: 700;">⭐ 4,9 von 5 Sternen</span> — 47 Bewertungen bei Google
      </p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class="testimonial-card card" data-reveal data-reveal-delay={String(i + 1)}>
          <div class="testimonial-quote" aria-hidden="true">"</div>
          <p class="testimonial-text">„{t.text}"</p>
          <div class="testimonial-footer">
            <div class="stars" aria-label={`${t.stars} von 5 Sternen`}>
              {'★'.repeat(t.stars)}
            </div>
            <div class="testimonial-author">
              <strong class="testimonial-name">{t.name}</strong>
              <span class="testimonial-location">{t.location}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .testimonials-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .testimonial-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .testimonial-quote {
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    color: var(--clr-accent);
    opacity: 0.25;
    user-select: none;
    margin-bottom: -1.5rem;
    margin-top: -0.5rem;
  }

  .testimonial-text {
    font-size: 0.9375rem;
    color: var(--clr-text);
    line-height: 1.7;
    font-style: italic;
    flex: 1;
  }

  .testimonial-footer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--clr-bg-alt);
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .testimonial-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--clr-text);
  }

  .testimonial-location {
    font-size: 0.8125rem;
    color: var(--clr-text-muted);
  }
</style>
