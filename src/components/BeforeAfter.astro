---
const projects = [
  {
    description: '20m-Esche in enger Wohnbebauung — Stück für Stück per SKT abgetragen',
    beforeLabel: 'Vorher',
    afterLabel: 'Nachher',
    beforeIcon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22V12"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M12 12C12 8 9 5 6 5s-3 3 0 5h6"/><path d="M12 12c0-4 3-7 6-7s3 3 0 5h-6"/></svg>`,
    afterIcon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>`
  },
  {
    description: 'Kronenpflege an zwei Altbuchen — mehr Licht, gesunder Schnitt',
    beforeLabel: 'Vorher',
    afterLabel: 'Nachher',
    beforeIcon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22V12"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M12 12C12 8 9 5 6 5s-3 3 0 5h6"/><path d="M12 12c0-4 3-7 6-7s3 3 0 5h-6"/></svg>`,
    afterIcon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>`
  },
  {
    description: 'Sturmschaden: Birke auf Garagendach — Soforthilfe am selben Tag',
    beforeLabel: 'Vorher',
    afterLabel: 'Nachher',
    beforeIcon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    afterIcon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>`
  }
];
---

<section class="section section--alt" id="projekte" aria-labelledby="projekte-headline">
  <div class="container">
    <div class="section__header" data-reveal>
      <h2 class="section__headline" id="projekte-headline">Unsere Arbeit spricht für sich</h2>
      <p class="section__sub">Echte Projekte in der Rhein-Neckar-Region.</p>
    </div>

    <div class="ba-grid">
      {projects.map((p, i) => (
        <div class="ba-card" data-reveal data-reveal-delay={String(i + 1)}>
          <div class="ba-images">
            <div class="ba-img ba-img--before">
              <div class="ba-img__label">Vorher</div>
              <div class="ba-img__icon" set:html={p.beforeIcon} />
              <p class="ba-img__hint">Ausgangssituation</p>
            </div>
            <div class="ba-divider" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </div>
            <div class="ba-img ba-img--after">
              <div class="ba-img__label">Nachher</div>
              <div class="ba-img__icon" set:html={p.afterIcon} />
              <p class="ba-img__hint">Ergebnis</p>
            </div>
          </div>
          <p class="ba-description">{p.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .ba-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .ba-card {
    background: var(--clr-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 300ms ease, box-shadow 300ms ease;
  }

  .ba-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .ba-images {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 180px;
  }

  .ba-img {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    position: relative;
  }

  .ba-img--before {
    background: #2D2A26;
    color: rgba(255,255,255,0.6);
  }

  .ba-img--after {
    background: #E8F5E0;
    color: var(--clr-primary);
  }

  .ba-img__label {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .ba-img--before .ba-img__label {
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7);
  }

  .ba-img--after .ba-img__label {
    background: rgba(27, 67, 50, 0.12);
    color: var(--clr-primary);
  }

  .ba-img__icon {
    opacity: 0.7;
  }

  .ba-img__hint {
    font-size: 0.6875rem;
    font-weight: 500;
    opacity: 0.7;
    text-align: center;
  }

  .ba-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--clr-accent);
    border-radius: 50%;
    color: var(--clr-white);
    z-index: 1;
    flex-shrink: 0;
  }

  .ba-description {
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    color: var(--clr-text-muted);
    line-height: 1.5;
    border-top: 1px solid var(--clr-bg-alt);
  }
</style>
